{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/tech/Lenovo.DE/dataset/system-time.schema.json",
  "title": "Lenovo.DE system time dataset schema (v2)",
  "type": "object",
  "required": [
    "schema_version",
    "collector",
    "source",
    "dataset",
    "item_count",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lnv.collector.dataset.v1"
    },
    "collector": {
      "type": "object",
      "required": [
        "vendor",
        "name",
        "version"
      ],
      "properties": {
        "vendor": {
          "const": "LNV.AsBuiltDoc"
        },
        "name": {
          "const": "LNV.AsBuiltDoc.Lenovo.DE"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object"
    },
    "dataset": {
      "const": "system-time"
    },
    "collected_at_utc": {
      "type": "string"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "patternProperties": {
          "^x-": {}
        },
        "required": [
          "systemId",
          "controllerRef",
          "ntpAcquisitionType",
          "ntpServers",
          "dhcpAcquiredServers",
          "ipv4DefaultRouter"
        ],
        "properties": {
          "systemId": {
            "type": "string",
            "minLength": 1
          },
          "controllerRef": {
            "type": "string",
            "minLength": 1
          },
          "ntpAcquisitionType": {
            "type": "string",
            "minLength": 1
          },
          "ntpServers": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "dhcpAcquiredServers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ipv4DefaultRouter": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "additionalProperties": true
}
