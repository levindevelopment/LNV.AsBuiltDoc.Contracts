{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/tech/Lenovo.DE/dataset/transport.schema.json",
  "title": "Lenovo.DE transport dataset schema (v2)",
  "type": "object",
  "required": [
    "schema_version",
    "collector",
    "source",
    "dataset",
    "item_count",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lnv.collector.dataset.v1"
    },
    "collector": {
      "type": "object",
      "required": [
        "vendor",
        "name",
        "version"
      ],
      "properties": {
        "vendor": {
          "const": "LNV.AsBuiltDoc"
        },
        "name": {
          "const": "LNV.AsBuiltDoc.Lenovo.DE"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object"
    },
    "dataset": {
      "const": "transport"
    },
    "collected_at_utc": {
      "type": "string"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "systemId",
          "activeTransport"
        ],
        "properties": {
          "systemId": {
            "type": "string",
            "minLength": 1
          },
          "activeTransport": {
            "type": "string",
            "enum": [
              "iscsi",
              "fc"
            ]
          },
          "iscsiIqn": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
