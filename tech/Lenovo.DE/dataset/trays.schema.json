{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/tech/Lenovo.DE/dataset/trays.schema.json",
  "title": "Lenovo.DE Trays Dataset (v2)",
  "type": "object",
  "required": [
    "schema_version",
    "collector",
    "source",
    "dataset",
    "item_count",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lnv.collector.dataset.v1"
    },
    "collector": {
      "type": "object",
      "required": [
        "vendor",
        "name",
        "version"
      ],
      "properties": {
        "vendor": {
          "const": "LNV.AsBuiltDoc"
        },
        "name": {
          "const": "LNV.AsBuiltDoc.Lenovo.DE"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object"
    },
    "dataset": {
      "const": "trays"
    },
    "collected_at_utc": {
      "type": "string"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "patternProperties": {
          "^x-": {}
        },
        "required": [
          "systemId",
          "trayId",
          "trayType",
          "trayRole",
          "status"
        ],
        "properties": {
          "systemId": {
            "type": "string",
            "minLength": 1
          },
          "trayId": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "trayType": {
            "type": [
              "string",
              "null"
            ],
            "description": "Hardware-reported tray type (e.g. de224c)."
          },
          "trayRole": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "controller-tray",
              "expansion-tray",
              null
            ]
          },
          "controllerModelName": {
            "type": [
              "string",
              "null"
            ],
            "description": "Controller/system model name (e.g. DE4200) surfaced for SDT-friendly display."
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          },
          "serialNumber": {
            "type": [
              "string",
              "null"
            ]
          },
          "partNumber": {
            "type": [
              "string",
              "null"
            ]
          },
          "vendorName": {
            "type": [
              "string",
              "null"
            ]
          },
          "manufacturer": {
            "type": [
              "string",
              "null"
            ]
          },
          "manufacturerDate": {
            "type": [
              "string",
              "integer",
              "null"
            ]
          },
          "numControllerSlots": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "numDriveSlots": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "driveTechnologies": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "hasConfigurableTrayId": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "hasTrayIdentityIndicator": {
            "type": [
              "boolean",
              "null"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": true
}
