{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/tech/Lenovo.DE/dataset/system-controllers.schema.json",
  "title": "Lenovo.DE system controllers dataset schema (v2)",
  "type": "object",
  "required": [
    "schema_version",
    "collector",
    "source",
    "dataset",
    "item_count",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lnv.collector.dataset.v1"
    },
    "collector": {
      "type": "object",
      "required": [
        "vendor",
        "name",
        "version"
      ],
      "properties": {
        "vendor": {
          "const": "LNV.AsBuiltDoc"
        },
        "name": {
          "const": "LNV.AsBuiltDoc.Lenovo.DE"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object"
    },
    "dataset": {
      "const": "system-controllers"
    },
    "collected_at_utc": {
      "type": "string"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "patternProperties": {
          "^x-": {}
        },
        "required": [
          "systemId",
          "controllerRef",
          "controllerLabel",
          "controllerSlot",
          "status",
          "appVersion",
          "bootVersion",
          "serialNumber",
          "trayId"
        ],
        "properties": {
          "systemId": {
            "type": "string",
            "minLength": 1
          },
          "controllerRef": {
            "type": "string",
            "minLength": 1
          },
          "controllerLabel": {
            "type": "string",
            "minLength": 1
          },
          "controllerSlot": {
            "type": "integer",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "appVersion": {
            "type": "string",
            "minLength": 1
          },
          "bootVersion": {
            "type": "string",
            "minLength": 1
          },
          "bootTime": {
            "type": [
              "string",
              "null"
            ],
            "description": "Controller boot time in UTC, formatted as YYYY-MM-DDTHH:MM:SS (no fractional seconds)."
          },
          "serialNumber": {
            "type": "string",
            "minLength": 1
          },
          "manufacturerDate": {
            "type": [
              "string",
              "null"
            ],
            "description": "Controller manufacturing date formatted as YYYY-MM-DD."
          },
          "trayId": {
            "type": "integer",
            "minimum": 0,
            "maximum": 99
          },
          "modelName": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
