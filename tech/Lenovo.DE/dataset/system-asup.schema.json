{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/tech/Lenovo.DE/dataset/system-asup.schema.json",
  "title": "Lenovo.DE system ASUP dataset schema (v2)",
  "type": "object",
  "required": [
    "schema_version",
    "collector",
    "source",
    "dataset",
    "item_count",
    "items"
  ],
  "properties": {
    "schema_version": {
      "const": "lnv.collector.dataset.v1"
    },
    "collector": {
      "type": "object",
      "required": [
        "vendor",
        "name",
        "version"
      ],
      "properties": {
        "vendor": {
          "const": "LNV.AsBuiltDoc"
        },
        "name": {
          "const": "LNV.AsBuiltDoc.Lenovo.DE"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object"
    },
    "dataset": {
      "const": "system-asup"
    },
    "collected_at_utc": {
      "type": "string"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "patternProperties": {
          "^x-": {}
        },
        "required": [
          "systemId",
          "asupCapable",
          "onDemandCapable",
          "asupEnabled",
          "onDemandEnabled",
          "remoteDiagsEnabled"
        ],
        "properties": {
          "systemId": {
            "type": "string",
            "minLength": 1
          },
          "asupCapable": {
            "type": "boolean"
          },
          "onDemandCapable": {
            "type": "boolean"
          },
          "asupEnabled": {
            "type": "boolean"
          },
          "onDemandEnabled": {
            "type": "boolean"
          },
          "remoteDiagsEnabled": {
            "type": "boolean"
          },
          "deliveryMethod": {
            "type": [
              "string",
              "null"
            ]
          },
          "routingType": {
            "type": [
              "string",
              "null"
            ]
          },
          "proxyHost": {
            "type": [
              "string",
              "null"
            ]
          },
          "proxyPort": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "proxyScript": {
            "type": [
              "string",
              "null"
            ]
          },
          "mailRelayServer": {
            "type": [
              "string",
              "null"
            ]
          },
          "mailSenderAddress": {
            "type": [
              "string",
              "null"
            ]
          },
          "destinationAddressList": {
            "type": [
              "array",
              "null"
            ]
          },
          "maxSizeLimitHttps": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "maxSizeLimitSmtp": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        }
      }
    }
  },
  "additionalProperties": true
}
